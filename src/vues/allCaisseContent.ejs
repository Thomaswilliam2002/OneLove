<!DOCTYPE html>
<html lang="en">

  
<!-- Mirrored from buybootstrap.com/demos/medflex/medflex-admin-dashboard/accordions.html by HTTrack Website Copier/3.x [XR&CO'2014], Thu, 15 May 2025 12:16:35 GMT -->
<%- include('head')%>

  <body>

    <!-- Page wrapper starts -->
    <div class="page-wrapper">

      <!-- App header starts -->
      <% if(user.Personnel.type_personnel === 'admin'){%>
        <%- include('header')%>
      <% }else{%>
        <%- include('header-staff')%>
      <% }%>
      <!-- App header ends -->

      <!-- Main container starts -->
      <div class="main-container">

        <!-- Sidebar wrapper starts -->
        <% if(user.Personnel.type_personnel === 'admin'){%>
          <%- include('menu')%>
        <% }else{%>
          <%- include('menu-staff')%>
        <% }%>
        <!-- Sidebar wrapper ends -->

        <!-- App container starts -->
        <div class="app-container">

          <!-- App hero header starts -->
          <div class="app-hero-header d-flex align-items-center">

            <!-- Breadcrumb starts -->
            <ol class="breadcrumb">
              <li class="breadcrumb-item">
                <i class="ri-home-8-line lh-1 pe-3 me-3 border-end"></i>
                <a href="/index">Home</a>
              </li>
              <li class="breadcrumb-item text-primary" aria-current="page">
                Liste des maison close
              </li>
            </ol>
            <!-- Breadcrumb ends -->

            <!-- Sales stats starts -->
            
            <!-- Sales stats ends -->

          </div>
          <!-- App Hero header ends -->

          <!-- App body starts -->
          <div class="app-body">
            <% if(caisses.length > 0){ %>
              <% caisses.forEach((caisse, index) => {%>
              <!-- Row starts -->
              <div class="row gx-3">
                <div class="col-sm-12">
                  <div class="accordion mb-3" id="accordionSpecialTitle<%= caisse.id_caisse %>">
                    <div class="accordion-item ">
                      <div class="accordion-header d-flex justify-content-between" id="headingSpecialTitle<%= caisse.id_caiss %>">
                          
                        
                          <div class="table-responsive ps-2">
                            <table  class="table truncate m-0 align-middle ">
                              <thead class="text-center">
                                <tr>
                                  <!-- <th>ID</th> -->
                                  <th><strong><%= caisse.nom %></strong></th>
                                  <th><strong><%= caisse.departement %></strong>: <%= caisse.sous_departement %></th>
                                  <th>
                                    <ul class="list-unstyled">
                                        <% caisse?.caissiers.forEach(personnel => { %>
                                          <li><%= personnel.nom %> <%= personnel.prenom %></li>
                                        <% }) %>
                                    </ul>
                                  </th>
                                </tr>
                              </thead>
                            </table>
                          </div>
                      
                          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                              data-bs-target="#collapseSpecialTitle<%= caisse.id_caiss %>" aria-expanded="true"
                              aria-controls="collapseSpecialTitle<%= caisse.id_caiss %>" style="width: auto;">
                              <!-- <div class="d-flex flex-column"></div> -->
                          </button>
                              <!-- <div class="d-flex flex-column"></div> -->
                          
                          
                      </div>
                      
                      <div id="collapseSpecialTitle<%= caisse.id_caiss %>" class="accordion-collapse collapse "
                        aria-labelledby="headingSpecialTitle<%= caisse.id_caiss %>" data-bs-parent="#accordionSpecialTitle<%= caisse.id_caiss %>">
                        <%caisse?.inventaire?.produits.forEach((produit, i) => {%>
                            <div class="accordion-body">
                                <div class="card-header d-flex align-items-center justify-content-between">
                                    <h5 class="card-title">Liste des Produits</h5>
                                </div>
                                <br>
                                <div class="table-responsive">
                                <table id="" class="table truncate m-0 align-middle customButtone" >
                                    <thead class="text-center">
                                    <tr>
                                        <th>ID</th>
                                        <th>Nom</th>
                                        <th>Prix Unitaire</th>
                                        <th>Quantiter Disponible</th>
                                    </tr>
                                    </thead>
                                    <tbody class="text-center">
                                        <tr>
                                        <td><%= i %></td>
                                        <td>
                                            <%= produit.nom %>
                                        </td>
                                        <td><%= produit.prix_unitaire %></td>
                                        <td><%= produit.quantite_disponible %></td>
                                        </tr>
                                    </tbody>
                                </table>
                                </div>
                            </div>
                        <% }) %>
                        <br>
                        <%caisse?.inventaire?.emballages.forEach((emballage, i) => {%>
                            <div class="accordion-body">
                                <div class="card-header d-flex align-items-center justify-content-between">
                                    <h5 class="card-title">Liste des Emballages</h5>
                                </div>
                                <br>
                                <div class="table-responsive">
                                <table id="" class="table truncate m-0 align-middle customButtone" >
                                    <thead class="text-center">
                                    <tr>
                                        <th>ID</th>
                                        <th>Nom</th>
                                        <th>Prix Unitaire</th>
                                        <th>Quantiter Disponible</th>
                                    </tr>
                                    </thead>
                                    <tbody class="text-center">
                                        <tr>
                                        <td><%= i %></td>
                                        <td>
                                            <%= emballage.nom %>
                                        </td>
                                        <td><%= emballage.prix_unitaire %></td>
                                        <td><%= emballage.quantite_disponible %></td>
                                        </tr>
                                    </tbody>
                                </table>
                                </div>
                            </div>
                        <% }) %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Row ends -->
              <% }) %>
            <% } else{ %>
              <div class="alert bg-white border alert-dismissible fade show text-info" role="alert">
                Aucune caisses n'a encore ete ajouter!
                <b>Veillez ajouter une caisse</b>
              </div>
            <% } %>
            <!-- Row starts -->
            
            <!-- Row ends -->
            <div class="table-responsive">
              <table id="" class="table m-0 align-middle customButtone">
                <thead class="text-center">
                  <tr>
                    <th>ID</th>
                    <th>Chambre</th>
                    <th>Maison close</th>
                    <th>Montant reçu</th> 
                    <th>Montant attendu</th>
                  </tr>
                </thead>
                <tbody class="text-center">
                  
                  <% i = 1; const today = new Date().toISOString().split('T')[0]; %>
                  <% let tta = 0; let ttr = 0 %>
                  <% chambres.forEach(chambre => { %> 
                    
                    <tr>
                      <td><%= i %></td>
                      <td><%= chambre.nom %></td>
                      <td><%= chambre.MaisonClose.nom %></td>

                      <td>
                        <% 
                          const journalDuJour = chambre.ChambreJournals.find(j => {
                            const journalDate = j.date;
                            return journalDate === today;
                          });
                          if(journalDuJour){
                            ttr += journalDuJour.loyer
                          }
                        %>

                        <%= journalDuJour ? journalDuJour.loyer : 0 %> FCFA
                      </td>

                      <td><%= chambre.loyer %> FCFA</td>
                    </tr>
                  <% i++ }) %>
                  <tfoot class="text-center">
                    <tr>
                      <td>-</td>
                      <td>-</td>
                      <td>Total</td>
                      <td><%= ttr %></td>
                      <td></td>
                    </tr>
                  </tfoot>
                </tbody>
              </table>
            </div>

          </div>
          <!-- App body ends -->

          <!-- App footer starts -->
          <div class="app-footer bg-white">
            <span>© OneLove admin 2026</span>
          </div>
          <!-- App footer ends -->

        </div>
        <!-- App container ends -->

      </div>
      <!-- Main container ends -->

    </div>
    <!-- Page wrapper ends -->

    <!-- *************
			************ JavaScript Files *************
		************* -->
    <!-- Required jQuery first, then Bootstrap Bundle JS -->
    <%- include('script')%>
    <script>
      window.addEventListener("pageshow", function (event) {
        var historyTraversal = event.persisted || 
                               (typeof window.performance != "undefined" && 
                                window.performance.navigation.type === 2);
        if (historyTraversal) {
            // Si l'utilisateur est revenu en arrière, on recharge la page proprement
            window.location.reload();
        }
      });
    </script>
  </body>
  

