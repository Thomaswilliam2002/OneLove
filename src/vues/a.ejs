                                .catch(_ => {
                                    console.error(_);
                                    res.redirect('/notFound');
                                    return; // On stoppe tout ici !
                                })
                        })
                        .catch(_ => {
                            console.error(_);
                            res.redirect('/notFound');
                            return; // On stoppe tout ici !
                        })
                })
                .catch(_ => {
                    console.error(_);
                    res.redirect('/notFound');
                    return; // On stoppe tout ici !
                })
        }
        else if(req.query.art === 'emballage'){
            Emballage.findByPk(req.params.id)
