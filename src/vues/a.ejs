deletePoste = (app) => {
  app.delete('/deletePoste/:id', protrctionRoot, authorise('admin', 'comptable'), async (req, res) => {
      try {
          const t = await sequelize.transaction();
          await Occupe.update({is_active: false}, {where: {id_poste: req.params.id}, transaction: t});
          //recuperer tout le personnel qui occupe ce poste
          const occupe = await Occupe.findAll(
              {
                  include: [
                      {model: Personnel, attributes: ['id_personnel'] , where: {is_active: true}}
                  ],
                  where: {id_poste: req.params.id}, transaction: t
              }
          );
          //tableau de personnel qui occupe ce poste
          const tabPersonnel = occupe.map(occupe => occupe.Personnel.id_personnel);
          // supprimer tout le personnel qui occupe ce poste
          await Personnel.update({is_active: false}, {
              where: {[Op.in]: [tabPersonnel]}, transaction: t
          });

          await t.commit();

          res.redirect('/allPoste?msg=Poste supprimer avec succes&tc=alert-success');
      } catch (error) {
          console.error(error);
          await t.rollback();
          res.redirect('/notFound');
          return; // On stoppe tout ici !
      }
  })
}

