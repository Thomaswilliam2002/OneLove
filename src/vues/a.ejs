deleteCaisse = (app) => {
  app.delete('/deleteCaisse/:id', protrctionRoot, authorise('admin', 'comptable'), async (req, res) => {
      try{
          const caisse = await Caisse.findByPk(req.params.id);
          if(!caisse) return res.redirect('/notFound');
          const allHistCaisse = await HistCaisse.findAll({ where: { id_caisse: req.params.id } });
          if(allHistCaisse.length > 0){
              for(hist of allHistCaisse){
                  if(hist.type === 'emballage'){
                      const qte = hist.quantiter;
                      const mj = Emballage.update({
                          quantiter: Sequelize.literal(`quantiter + ${qte}`),
                      }, { where: { id_emballage: hist.id_probal } });
                  }else if(hist.type === 'produit'){
                      const qte = hist.quantiter;
                      const mj = Produit.update({
                          quantiter: Sequelize.literal(`quantiter + ${qte}`),
                      }, { where: { id_produit: hist.id_probal } });
                  }
              }
          }
          caisse.destroy({ where: { id_caisse: req.params.id } });
          res.redirect('/allCaisse?msg=sup');
      }
      catch(e){
          console.error(e);
          res.redirect('/notFound');
      }
  })
}
