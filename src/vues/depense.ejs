                                                            <input type="text" class="form-control" id="a1" placeholder="Entrer le nom" value="<%= depense.nom%>" name="nom" required>
                                                          </div>
                                                        </div>
                                                        <div class="col-xxl-3 col-lg-4 col-sm-6">
                                                            <div class="mb-3">
                                                              <label class="form-label" for="a1">Montant<span class="text-danger">*</span></label>
                                                              <input type="number" min="1" step="0.01" max="999999999" class="form-control" value="<%= depense.montant%>" name="montant" required>
                                                            </div>
