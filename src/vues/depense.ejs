                                                  </div>
                                                  <div class="modal-footer">
                                                    <div class="col-sm-12">
                                                      <div class="d-flex gap-2 justify-content-end">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                          annuler
                                                        </button>
                                                        <button type="submit" class="btn btn-primary" <% categories.length !== 0 ? '' : 'desabled' %> >Appliquer les modification</button>
                                                      </div>
                                                    </div>
                                                    <!-- <a href="/updatePoste/<%= depense.id_depense %>" class="btn btn-danger"
                                                      data-bs-title="Modifier">
                                                      Appliquer les modification
                                                    </a> -->
                                                  </div>
                                                </form>
                                              </div>
                                            </div>
                                          </div>
                                      <!-- Card ends -->
                                  </div>
                                </td>
                              </tr>
                          <% }) %>
                        </tbody>
                      
                        <!-- <tr class="bg-info"><td colspan="3" id="resulta">ok</td></tr> -->
                      </table>
                      <table id="" class="table truncate m-0 align-middle dataTable">
                        <thead class="text-center">
