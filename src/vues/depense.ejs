                                                              <!-- <input type="text" class="form-control" id="a5" placeholder="Entrer le post occuper" name="poste" required> -->
                                                              <select class="form-select" id="categorie" name="categ">
                                                                <% if(categories.length !== 0){ categories.forEach(categorie => { %>
                                                                      <option value="<%= categorie.id_categ %>"><%= categorie.nom %></option>
                                                                <% }) }else{ %>
                                                                  <option value="null">Aucune categorie disponinble</option>
                                                                <% } %>
                                                              </select>
                                                            </div>
                                                        </div>
                                                        <div class="col-xxl-3 col-lg-4 col-sm-6">
                                                          <div class="mb-3">
                                                            <label class="form-label" for="a2">Description <span class="text-danger">*</span></label>
                                                            <textarea class="form-control" id="a8" placeholder="Enter une description"  rows="2" name="desc"><%= depense.description%></textarea>
                                                          </div>
                                                        </div>
