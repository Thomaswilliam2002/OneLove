            <div class="row gx-3">
              <div class="col-sm-12">
                <div class="card">
                  <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="card-title">Ajouter une nouvelle Dépense</h5>
                  </div>
                  <div class="card-body">
                    <form action="/addDepense" method="post" id="formAddDepense">
                      <!-- Row starts -->
                      <div class="row gx-3">
                        <div class="col-sm-12">
