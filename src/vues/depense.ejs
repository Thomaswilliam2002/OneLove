              <div class="card mb-3">
                <div class="card-header">
                  <h5 class="card-title">Courbre de variation des Dépense</h5>
                </div>
                <!-- ---------------------------------------------------------------- -->
                <div class="">
                  <div class="">
                    <div class="card-body">
                      <div id="carouselExampleIndicators" class="carousel slide" data-bs-ride="false">
                        <div class="carousel-indicators">
