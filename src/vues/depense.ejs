                        </div>
                        <div class="col-xxl-3 col-lg-4 col-sm-6">
                          <div class="mb-3">
                            <label class="form-label" for="a1">Nom de la dépense<span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="a1" style="text-transform: capitalize" placeholder="Entrer le nom" name="nom" required>
                          </div>
                        </div>
                        <div class="col-xxl-3 col-lg-4 col-sm-6">
                            <div class="mb-3">
                              <label class="form-label" for="a1">Montant<span class="text-danger">*</span></label>
                              <input type="number" min="1" step="0.01" max="999999999" class="form-control" name="montant" required>
                            </div>
                        </div>
                        <div class="col-xxl-3 col-lg-4 col-sm-6">
                            <div class="mb-3">
                              <label class="form-label" for="a1">Date <span class="text-danger">*</span></label>
                              <input type="date" class="form-control" placeholder="Date" name="date" required>
