              </div>
            </div>

            <br>

            <div class="row gx-3">
              <div class="col-sm-12">
  
                <!-- Card start -->
                <div class="card">
                  <div class="card-header">
  
                    <!-- List start -->
                    <div class="d-flex flex-wrap gap-1" id="diagram">
                      
                    </div>
