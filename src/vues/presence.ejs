<!DOCTYPE html>
<html lang="fr">

<%- include('head') %>

<body>
  <div class="page-wrapper">

    <% if(user.Personnel.type_personnel === 'admin'){ %>
      <%- include('header') %>
    <% } else { %>
      <%- include('header-staff') %>
    <% } %>

    <div class="main-container">

      <% if(user.Personnel.type_personnel === 'admin'){ %>
        <%- include('menu') %>
      <% } else { %>
        <%- include('menu-staff') %>
      <% } %>

      <div class="app-container">

        <div class="app-hero-header d-flex align-items-center">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><i class="ri-home-8-line lh-1 pr-3"></i> Accueil</li>
            <li class="breadcrumb-item text-primary" aria-current="page">Gestion des Présences</li>
          </ol>
        </div>

        <div class="app-body">

          <% if(msg) { %>
            <div class="alert <%= tc || 'alert-info' %> alert-dismissible fade show" role="alert">
              <%= msg %>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
          <% } %>

          <div class="card mb-3">
            <div class="card-body">
              <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-success d-flex align-items-center shadow-sm" data-bs-toggle="modal" data-bs-target="#modalArrivee">
                  <i class="ri-login-circle-line fs-4 me-1"></i> Pointer Arrivée
                </button>
                <button class="btn btn-primary d-flex align-items-center shadow-sm" data-bs-toggle="modal" data-bs-target="#modalDepart">
                  <i class="ri-logout-circle-line fs-4 me-1"></i> Pointer Départ
                </button>
                <button class="btn btn-danger d-flex align-items-center shadow-sm" data-bs-toggle="modal" data-bs-target="#modalAbsenceDebut">
                  <i class="ri-user-unfollow-line fs-4 me-1"></i> Début Absence
                </button>
                <button class="btn btn-warning d-flex align-items-center shadow-sm" data-bs-toggle="modal" data-bs-target="#modalAbsenceFin">
                  <i class="ri-user-follow-line fs-4 me-1"></i> Fin Absence
                </button>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-header">
                  <h5 class="card-title">Registre des Présences & Absences</h5>
                </div>
                <div class="card-body">
                  <div class="table-responsive">
                    <table class="table table-hover align-middle customButtone">
                      <thead class="text-center">
                        <tr>
                          <th>Personnel</th>
                          <th>État</th>
                          <th>Début</th>
                          <th>Fin</th>
                          <th>Heures (Arr/Dep)</th>
                          <th>Justification</th>
                          <th>Actions</th>
                        </tr>
                      </thead>
                      <tbody class="text-center">
                        <% presences.forEach(p => { %>
                          <%if(['admin', 'comptable'].includes(user.Personnel.type_personnel)){%>
                            <tr>
                              <td>
                                <strong><%= p.Personnel.nom %> <%= p.Personnel.prenom %></strong>
                              </td>
                              <td>
                                <span class="badge <%= p.etat_presence === 'Present' ? 'bg-success' : 'bg-danger' %>">
                                  <%= p.etat_presence %>
                                </span>
                              </td>
                              <td><%= p.date_debut %></td>
                              <td><%= p.date_fin || '---' %></td>
                              <td>
                                <small>
                                  <i class="ri-time-line text-success"></i> <%= p.heure_arriver || '--:--' %> <br>
                                  <i class="ri-time-line text-danger"></i> <%= p.heure_deppart || '--:--' %>
                                </small>
                              </td>
                              <td><%= p.etat_presence === 'Absent' ? p.justification_absence : '---' %></td>
                              <td>
                                <form action="/deletePresence/<%= p.id_presence %>?_method=DELETE" method="POST" onsubmit="return confirm('Supprimer cet enregistrement ?')">
                                  <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="ri-delete-bin-line"></i>
                                  </button>
                                </form>
                              </td>
                            </tr>
                          <%} else { if(p.Personnel.id_personnel === user.Personnel.id_personnel) {%>
                            <tr>
                              <td>
                                <strong><%= p.Personnel.nom %> <%= p.Personnel.prenom %></strong>
                              </td>
                              <td>
                                <span class="badge <%= p.etat_presence === 'Present' ? 'bg-success' : 'bg-danger' %>">
                                  <%= p.etat_presence %>
                                </span>
                              </td>
                              <td><%= p.date_debut %></td>
                              <td><%= p.date_fin || '---' %></td>
                              <td>
                                <small>
                                  <i class="ri-time-line text-success"></i> <%= p.heure_arriver || '--:--' %> <br>
                                  <i class="ri-time-line text-danger"></i> <%= p.heure_deppart || '--:--' %>
                                </small>
                              </td>
                              <td><%= p.etat_presence === 'Absent' ? p.justification_absence : '---' %></td>
                              <td>
                                <form action="/deletePresence/<%= p.id_presence %>?_method=DELETE" method="POST" onsubmit="return confirm('Supprimer cet enregistrement ?')">
                                  <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="ri-delete-bin-line"></i>
                                  </button>
                                </form>
                              </td>
                            </tr>
                          <%}}%>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div> <div class="modal fade" id="modalArrivee" tabindex="-1">
          <div class="modal-dialog">
            <form action="/addArrivee" method="POST" class="modal-content">
              <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Pointer une prise de service</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <%if(['admin', 'comptable'].includes(user.Personnel.type_personnel)){%>
                  <div class="mb-3 text-center">
                    <label class="form-label">Employé de retour</label>
                    <select name="id_personnel" class="form-select" required>
                      <% personnels.forEach(p => { if(p.type_personnel !== 'admin'){%>
                        <option value="<%= p.id_personnel %>"><%= p.nom %> <%= p.prenom %></option>
                      <% }}) %>
                    </select>
                  </div>
                <%}else{%>
                  <div class="mb-3 text-center">
                    <label class="form-label">Nom & Prenom</label>
                    <input type="text" name="" value="<%= user.Personnel.nom %> <%= user.Personnel.prenom %>" class="form-control" required disabled>
                  </div>
                  <input type="hidden" name="id_personnel" value="<%= user.Personnel.id_personnel %>" class="form-control" >
                <%}%>
                <div class="mb-3 text-center">
                  <label class="form-label">Date de début</label>
                  <input type="date" name="date_debut" class="form-control" required>
                </div>
                <div class="mb-3 text-center">
                  <label class="form-label">Heure d'arrivée</label>
                  <input type="time" name="heure_arriver" class="form-control" value="<%= new Date().toLocaleTimeString('fr-FR', {hour: '2-digit', minute:'2-digit'}) %>" required>
                </div>
                <input type="hidden" name="pointeur" value="<%= user.Personnel.id_personnel %>">
              </div>
              <div class="modal-footer">
                <button type="submit" class="btn btn-success w-100">Valider l'arrivée</button>
              </div>
            </form>
          </div>
        </div>

        <div class="modal fade" id="modalDepart" tabindex="-1">
          <div class="modal-dialog">
            <form action="/updateDepart" method="POST" class="modal-content">
              <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Enregistrer une fin de service</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <%if(['admin', 'comptable'].includes(user.Personnel.type_personnel)){%>
                  <div class="mb-3 text-center">
                    <label class="form-label">Employé de retour</label>
                    <select name="id_personnel" class="form-select" required>
                      <% personnels.forEach(p => { if(p.type_personnel !== 'admin'){%>
                        <option value="<%= p.id_personnel %>"><%= p.nom %> <%= p.prenom %></option>
                      <% }}) %>
                    </select>
                  </div>
                <%}else{%>
                  <div class="mb-3 text-center">
                    <label class="form-label">Nom & Prenom</label>
                    <input type="text" name="" value="<%= user.Personnel.nom %> <%= user.Personnel.prenom %>" class="form-control" required disabled>
                  </div>
                  <input type="hidden" name="id_personnel" value="<%= user.Personnel.id_personnel %>" class="form-control" >
                <%}%>
                <div class="mb-3 text-center">
                  <label class="form-label">Date de fin</label>
                  <input type="date" name="date_fin" class="form-control" required>
                </div>
                <div class="mb-3 text-center">
                  <label class="form-label">Heure de départ</label>
                  <input type="time" name="heure_deppart" class="form-control" required>
                </div>
                <input type="hidden" name="pointeur" value="<%= user.Personnel.id_personnel %>">
              </div>
              <div class="modal-footer">
                <button type="submit" class="btn btn-primary w-100">Valider le départ</button>
              </div>
            </form>
          </div>
        </div>
        <!-- Les absence -->
        <div class="modal fade" id="modalAbsenceDebut" tabindex="-1">
          <div class="modal-dialog">
            <form action="/addAbsenceDebut" method="POST" class="modal-content">
              <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Déclarer une Absence</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <%if(['admin', 'comptable'].includes(user.Personnel.type_personnel)){%>
                  <div class="mb-3 text-center">
                    <label class="form-label">Employé de retour</label>
                    <select name="id_personnel" class="form-select" required>
                      <% personnels.forEach(p => { if(p.type_personnel !== 'admin'){%>
                        <option value="<%= p.id_personnel %>"><%= p.nom %> <%= p.prenom %></option>
                      <% }}) %>
                    </select>
                  </div>
                <%}else{%>
                  <div class="mb-3 text-center">
                    <label class="form-label">Nom & Prenom</label>
                    <input type="text" name="" value="<%= user.Personnel.nom %> <%= user.Personnel.prenom %>" class="form-control" required disabled>
                  </div>
                  <input type="hidden" name="id_personnel" value="<%= user.Personnel.id_personnel %>" class="form-control" >
                <%}%>
                <div class="mb-3 text-center">
                  <label class="form-label">Date de début</label>
                  <input type="date" name="date_debut" class="form-control" required>
                </div>
                <div class="mb-3 text-center">
                  <label class="form-label">Heure de début</label>
                  <input type="time" name="heure_debut" class="form-control" required>
                </div>
              <input type="hidden" name="pointeur" value="<%= user.Personnel.id_personnel %>">
              <div class="mb-3 text-center">
                  <label class="form-label">Justification</label>
                  <textarea name="justification" class="form-control" placeholder="Raison de l'absence..."></textarea>
                </div>
              </div>
              <div class="modal-footer">
                <button type="submit" class="btn btn-danger w-100">Enregistrer l'absence</button>
              </div>
            </form>
          </div>
        </div>

        <div class="modal fade" id="modalAbsenceFin" tabindex="-1">
          <div class="modal-dialog">
            <form action="/updateAbsenceFin" method="POST" class="modal-content">
              <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">Retour d'Absence</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <%if(['admin', 'comptable'].includes(user.Personnel.type_personnel)){%>
                  <div class="mb-3 text-center">
                    <label class="form-label">Employé de retour</label>
                    <select name="id_personnel" class="form-select" required>
                      <% personnels.forEach(p => { if(p.type_personnel !== 'admin'){%>
                        <option value="<%= p.id_personnel %>"><%= p.nom %> <%= p.prenom %></option>
                      <% }}) %>
                    </select>
                  </div>
                <%}else{%>
                  <div class="mb-3 text-center">
                    <label class="form-label">Nom & Prenom</label>
                    <input type="text" name="" value="<%= user.Personnel.nom %> <%= user.Personnel.prenom %>" class="form-control" required disabled>
                  </div>
                  <input type="hidden" name="id_personnel" value="<%= user.Personnel.id_personnel %>" class="form-control" >
                <%}%>
                <div class="mb-3 text-center">
                  <label class="form-label">Date de retour (Fin)</label>
                  <input type="date" name="date_fin" class="form-control" required>
                </div>
                <div class="mb-3 text-center">
                  <label class="form-label">Heure d'arrivée</label>
                  <input type="time" name="heure_fin" class="form-control" value="<%= new Date().toLocaleTimeString('fr-FR', {hour: '2-digit', minute:'2-digit'}) %>" required>
                </div>
                <input type="hidden" name="pointeur" value="<%= user.Personnel.id_personnel %>">
              </div>
              <div class="modal-footer">
                <button type="submit" class="btn btn-warning w-100 text-dark">Clôturer l'absence</button>
              </div>
            </form>
          </div>
        </div>

        <div class="app-footer bg-white text-center py-3">
          <span>© OneLove Admin 2026</span>
        </div>

      </div>
    </div>
  </div>

  <%- include('script') %>
  <script>
    
  </script>
</body>
</html>