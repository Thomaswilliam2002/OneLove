<!DOCTYPE html>
<html lang="en">

  
<!-- Mirrored from buybootstrap.com/demos/medflex/medflex-admin-dashboard/add-staff.html by HTTrack Website Copier/3.x [XR&CO'2014], Thu, 15 May 2025 12:16:13 GMT -->
<%- include('head')%>
<body style="background-color: rgb(56, 100, 158);">
  <div class="page-wrapper">
    <% if(user.Personnel.type_personnel === 'admin'){%>
      <%- include('header')%>
    <% }else{%>
      <%- include('header-staff')%>
    <% }%>

    <div class="main-container">
      <% if(user.Personnel.type_personnel === 'admin'){%>
        <%- include('menu')%>
      <% }else{%>
        <%- include('menu-staff')%>
      <% }%>

      <div class="app-container">
        <div class="app-body">
          <% if(msg) {%>
            <div class="alert bg-white border alert-dismissible fade show <%= (typeof tc !== 'undefined' && tc) ? tc : 'alert-success' %>" role="alert">
              <%= msg %>.
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% }%>
          <% if(caisses.length === 0) { %>
            <div class="alert bg-white border text-info text-center">
              <h4>Aucune caisse n'est associée à votre compte pour le moment.</h4>
            </div>
          <% } else { %>
            <% caisses.forEach(caisse => { %>
              <div class="card mb-5 shadow-sm">
                <div class="card-header d-flex justify-content-around align-items-center" style="background: #2b3a4a; color: white;">
                  <h4 class="m-0">Caisse : <%= caisse.nom_caisse %></h4>
                  <span class="badge bg-info text-dark">Département : <%= caisse.departement %></span>
                  <span class="badge bg-info text-dark">Sous Département : <%= caisse.sous_departement %></span>
                </div>
                
                <div class="card-body">
                  <div class="row">
                    <% caisse.inventaire.produits.forEach(p => { %>
                      <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">
                        <div class="card border-primary mb-3">
                          <div class="card-body text-center">
                            <h5 class="card-title mt-2"><%= p.nom %></h5>
                            <p class="card-text mb-1">
                              <strong>Prix :</strong> <%= p.prix_unitaire %> FCFA<br>
                              <strong>Disponible :</strong> 
                              <span class="badge <%= p.quantite_disponible > 5 ? 'bg-success' : 'bg-danger' %>">
                                <%= p.quantite_disponible %>
                              </span>
                            </p>
                            <% if(p.quantite_disponible > 0) { %>
                              <button class="btn btn-primary w-100" data-bs-toggle="modal" data-bs-target="#vendreProd<%= p.id %><%= caisse.id_caisse %>">
                                Mise a jour
                              </button>
                            <% } else { %>
                              <button class="btn btn-secondary w-100" disabled>Rupture</button>
                            <% } %>
                          </div>
                        </div>
                      </div>
                      <%
                        const params = {
                          item: p,
                          type: 'produit',
                          id_caisse: caisse?.id_caisse,
                          lieu: caisse?.departement,
                          id_caissier: personnel?.id_personnel || null
                        };
                      %>

                      <%- include('partials/modalVente', params) %>
                    <% }) %>

                    <% caisse.inventaire.emballages.forEach(e => { %>
                      <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">
                        <div class="card border-warning mb-3">
                          <div class="card-body text-center bg-light">
                            <h5 class="card-title"><%= e.nom %></h5>  
                            <p class="card-text mb-1">
                              <strong>Prix :</strong> <%= e.prix_unitaire %> FCFA<br>
                              <strong>Disponible :</strong>
                              <span class="badge <%= e.quantite_disponible > 5 ? 'bg-success' : 'bg-danger' %>">
                                <%= e.quantite_disponible %>
                              </span>
                            </p>
                            <button class="btn btn-warning w-100" data-bs-toggle="modal" data-bs-target="#vendreEmb<%= e.id %><%= caisse.id_caisse %>">
                              Mise a jour
                            </button>
                          </div>
                        </div>
                      </div>
                      <%
                        const params = {
                          item: e,
                          type: 'emballage',
                          id_caisse: caisse?.id_caisse,
                          lieu: caisse?.departement,
                          id_caissier: personnel?.id_personnel || null
                        };
                      %>
                      <%- include('partials/modalVente', params) %>
                    <% }) %>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
        <div class="app-footer bg-white">
          <span>© OneLove admin 2026</span>
        </div>
      </div>
    </div>
  </div>
  <%- include('script')%>
  <script>
    window.addEventListener("pageshow", function (event) {
      var historyTraversal = event.persisted || 
                              (typeof window.performance != "undefined" && 
                              window.performance.navigation.type === 2);
      if (historyTraversal) {
          // Si l'utilisateur est revenu en arrière, on recharge la page proprement
          window.location.reload();
      }
    });
  </script>
</body>
</html>