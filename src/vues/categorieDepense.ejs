<!DOCTYPE html>
<html lang="en">

<%- include('head')%>

  <body>

    <div class="page-wrapper">

      <% if(user.Personnel.type_personnel === 'admin'){%>
        <%- include('header')%>
      <% }else{%>
        <%- include('header-staff')%>
      <% }%>

      <div class="main-container">

        <% if(user.Personnel.type_personnel === 'admin'){%>
          <%- include('menu')%>
        <% }else{%>
          <%- include('menu-staff')%>
        <% }%>

        <div class="app-container">

          <div class="app-hero-header d-flex align-items-center">
            <ol class="breadcrumb">
              <li class="breadcrumb-item">
                <i class="ri-home-8-line lh-1 pe-3 me-3 border-end"></i>
                <a href="/index">Accueil</a>
              </li>
              <li class="breadcrumb-item text-primary" aria-current="page">
                Catégorie de Dépense
              </li>
            </ol>
          </div>

          <div class="app-body">
            <% if(msg) {%>
                <div class="alert bg-white border alert-dismissible fade show <%= text_color%>" role="alert">
                <b><%= msg%></b>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% }%>

            <div class="row gx-3">
              <div class="col-sm-12">
                <div class="card">
                  <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="card-title">Liste des Catégorie</h5>
                    <a href="#formAddCategorieDepense" class="btn btn-primary ms-auto">Ajouter une nouvelle Catégorie</a>
                  </div>
                  <div class="card-body">
                    <div class="table-responsive">
                      <table id="customButtons" class="table truncate m-0 align-middle dataTable">
                        <thead class="text-center">
                          <tr>
                            <th>ID</th>
                            <th>Nom de la Catégorie</th>
                            <th>Description</th>
                            <th>Action</th>
                          </tr>
                        </thead>
                        <tbody class="text-center" id="tbody">
                          <% categories.forEach(categorie => { %>
                            <tr>
                              <td><%= categorie.id_categ %></td>
                              <td><%= categorie.nom %></td>
                              <td><%= categorie.description %></td>
                              <td>
                                <div class="d-inline-flex gap-1">
                                    <button type="button" data-bs-toggle="modal" data-bs-target="#del<%= categorie.id_categ %>" class="btn btn-outline-danger btn-sm">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                    
                                    <button type="button" data-bs-toggle="modal" data-bs-target="#edit<%= categorie.id_categ %>" class="btn btn-outline-success btn-sm">
                                        <i class="ri-edit-box-line"></i>
                                    </button>
                                </div>

                                <div class="modal fade" id="del<%= categorie.id_categ %>" tabindex="-1" aria-hidden="true">
                                  <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                      <div class="modal-header">
                                        <h5 class="modal-title">Confirmer la suppression</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                      </div>
                                      <div class="modal-body">
                                        <p>Voulez-vous supprimer la catégorie <strong><%= categorie.nom %></strong> ?</p>
                                      </div>
                                      <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                                        <form action="/deleteCategorieDepense/<%= categorie.id_categ %>?_method=DELETE" method="post">
                                            <button type="submit" class="btn btn-danger">Supprimer</button>
                                        </form>
                                      </div>
                                    </div>
                                  </div>
                                </div>

                                <div class="modal fade" id="edit<%= categorie.id_categ %>" tabindex="-1" aria-hidden="true">
                                  <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                      <div class="modal-header">
                                        <h5 class="modal-title">Modification</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                      </div>
                                      <form action="/updateCategorieDepense/<%= categorie.id_categ %>?_method=PUT" method="post">
                                        <div class="modal-body text-start">
                                          <div class="row gx-3">
                                            <div class="col-sm-12 mb-3">
                                                <label class="form-label">Nom de la catégorie</label>
                                                <input type="text" class="form-control" value="<%= categorie.nom%>" name="nom" required>
                                            </div>
                                            <div class="col-sm-12 mb-3">
                                                <label class="form-label">Description</label>
                                                <textarea class="form-control" rows="3" name="desc"><%= categorie.description%></textarea>
                                            </div>
                                          </div>
                                        </div>
                                        <div class="modal-footer">
                                          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                                          <button type="submit" class="btn btn-primary">Appliquer les modifications</button>
                                        </div>
                                      </form>
                                    </div>
                                  </div>
                                </div>
                              </td>
                            </tr>
                          <% }) %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="mb-5"></div> <div class="row gx-3" id="formAddCategorieDepense">
              <div class="col-sm-12">
                <div class="card">
                  <div class="card-header">
                    <h5 class="card-title">Ajouter une nouvelle Catégorie</h5>
                  </div>
                  <div class="card-body">
                    <form action="/addCategorieDepense" method="post">
                      <div class="row gx-3">
                        <div class="col-md-6 col-sm-12 mb-3">
                            <label class="form-label">Nom de la Catégorie</label>
                            <input type="text" class="form-control" style="text-transform: capitalize;" placeholder="Entrer le nom" name="nom" required>
                        </div>
                        <div class="col-md-6 col-sm-12 mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" placeholder="Entrer une description" rows="2" name="desc"></textarea>
                        </div>
                      </div>
                      <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">Ajouter la catégorie</button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="app-footer bg-white">
            <span>© OneLove admin 2026</span>
          </div>

        </div>
        </div>
      </div>
    <%- include('script')%>
    
    <script>
      window.addEventListener("pageshow", function (event) {
        if (event.persisted || (typeof window.performance != "undefined" && window.performance.navigation.type === 2)) {
            window.location.reload();
        }
      });
    </script>
  </body>
</html>