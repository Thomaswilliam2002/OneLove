    <script>
      window.addEventListener("pageshow", function (event) {
        var historyTraversal = event.persisted || 
                               (typeof window.performance != "undefined" && 
                                window.performance.navigation.type === 2);
        if (historyTraversal) {
            // Si l'utilisateur est revenu en arrière, on recharge la page proprement
            window.location.reload();
        }
      });

    // Sélection des éléments
    const prestataire = document.getElementById('prestataire');
    const presPrenom = document.getElementById('presPrenom'); // L'input Prénom
    const presNom = document.getElementById('presNom');       // L'input Nom

    // Fonction pour mettre à jour l'affichage en temps réel
    const updateDisplay = () => {
        const nom = presNom.value.trim().toUpperCase(); // Souvent le Nom est en majuscules
        const prenom = presPrenom.value.trim();
        
        if (nom === "" && prenom === "") {
            prestataire.innerText = ""; // Valeur par défaut
        } else {
            prestataire.innerText = `${nom} ${prenom}`.trim();
        }
    };

    // Vérification que les éléments existent avant d'ajouter les écouteurs
    if (presNom && presPrenom && prestataire) {
        presNom.addEventListener('input', updateDisplay);
        presPrenom.addEventListener('input', updateDisplay);
    }
    function calculerPaie() {
      // 🔹 TOTAL BRUT
      let totalBrut = 0;
      document.querySelectorAll('.brut').forEach(el => {
        totalBrut += Number(el.value) || 0;
      });

      // 🔹 statut déclaré
      const declarer = document.getElementById('flexCheckChecked').checked;

      let cnss = 0;
      let aib = 0;

      if (declarer) {
        cnss = totalBrut * 0.036;
        aib = 0;
      } else {
        cnss = 0;
        aib = totalBrut * 0.05;
      }

      // 🔹 retenues saisies manuellement
      const its       = Number(document.getElementById('its')?.value) || 0;
      const avance    = Number(document.getElementById('avance')?.value) || 0;
      const sanction  = Number(document.getElementById('sanction')?.value) || 0;
      const manquant  = Number(document.getElementById('manquant')?.value) || 0;

      // 🔹 RETENUE SALARIALE TOTALE
      const retenueSalariale =
        its + aib + avance + sanction + manquant + cnss;

      // 🔹 SALAIRE NET
      const salaireNet = totalBrut - retenueSalariale;

      // 🔹 affichage
      document.getElementById('totalBrut').value = totalBrut.toFixed(2);
      document.getElementById('cnss').value = cnss.toFixed(2);
      document.getElementById('aib').value = aib.toFixed(2);
      document.getElementById('retenueSalariale').value = retenueSalariale.toFixed(2);
      document.getElementById('salaireNet').value = salaireNet.toFixed(2);
    }

    // 🔥 recalcul automatique (Excel-like)
    document.querySelectorAll('.brut, .retenue').forEach(el => {
      el.addEventListener('input', calculerPaie);
    });

    document.getElementById('flexCheckChecked').addEventListener('change', calculerPaie);
    // ------------------------------------------------------------------------------------------------------
    

    document.getElementById('btnExportPDF').addEventListener('click', function() {
        const h2 = document.getElementById("h2");
        const lieu = document.getElementById("lieu");
        const containerCheck = document.getElementById("container_check");
        const invoice = document.querySelector('.create-invoice-wrapper');

        // 1. STYLE TEMPORAIRE POUR LE PDF
        const style = document.createElement("style");
        style.id = "pdf-temp-style";
        style.innerHTML = `
        /* On cible l'input, le conteneur du groupe, et les spans/icônes à l'intérieur */
        input, 
        select, 
        .form-control, 
        .input-group, 
        .input-group-text, 
        .aussi {
          border: none !important;
          outline: none !important;
          box-shadow: none !important;
          background: transparent !important;
          appearance: none !important;
          -webkit-appearance: none !important;
        }

        /* On force la suppression des bordures séparatrices à l'intérieur du groupe */
        .input-group-text {
          border-color: transparent !important;
        }

        input::placeholder {
          color: transparent !important;
        }
      `;
        document.head.appendChild(style);

        document.getElementById("container_check").style.display = "none";

        document.head.appendChild(style);

        document.querySelectorAll("input").forEach(input => {
          input.placeholder = "";
        });

      document.querySelectorAll('.hide-in-pdf').forEach(el => {
        el.style.display = 'none';
      });

        // 2. PRÉPARATION DU CONTENU
        if (containerCheck) containerCheck.style.visibility = "hidden";
        
        // Masquer les boutons et éléments inutiles
        document.querySelectorAll('.hide-in-pdf').forEach(el => {
            el.style.display = 'none';
        });

        // Gestion du Lieu (Passage de l'input au texte h2)
        if (lieu && h2) {
            h2.innerText = lieu.value;
            h2.style.display = "block";
            lieu.style.display = "none";
        }

        // On remonte en haut pour éviter les bugs de capture html2canvas
        window.scrollTo(0, 0);

        // 3. GÉNÉRATION DU PDF
        setTimeout(() => {
            html2canvas(invoice, {
                scale: 2, // Qualité supérieure
                useCORS: true,
                logging: false,
                scrollY: -window.scrollY, // Capture depuis le haut
                windowHeight: invoice.scrollHeight // Prend TOUTE la hauteur réelle
            }).then(canvas => {
                const imgData = canvas.toDataURL('image/png');
                
                // Initialisation de jsPDF (Format A4 Portrait)
                const { jsPDF } = window.jspdf;
                const pdf = new jsPDF('p', 'mm', 'a4');
                
                const pdfWidth = pdf.internal.pageSize.getWidth();  // 210mm
                const pdfHeight = pdf.internal.pageSize.getHeight(); // 297mm

                // Calcul des dimensions de l'image pour le PDF
                let imgWidth = pdfWidth;
                let imgHeight = (canvas.height * pdfWidth) / canvas.width;

                // --- AJUSTEMENT POUR QUE TOUT TIENNE SUR UNE PAGE ---
                let finalWidth = imgWidth;
                let finalHeight = imgHeight;
                let xOffset = 0;

                if (imgHeight > pdfHeight) {
                    // Si l'image est plus haute que le A4, on réduit l'échelle
                    const ratio = pdfHeight / imgHeight;
                    finalHeight = pdfHeight;
                    finalWidth = imgWidth * ratio;
                    // On centre l'image horizontalement si elle a rétréci
                    xOffset = (pdfWidth - finalWidth) / 2;
                }

                pdf.addImage(imgData, 'PNG', xOffset, 0, finalWidth, finalHeight);
                pdf.save('facture.pdf');

                // 4. RESTAURATION DU DOM (Avant le reload pour la propreté)
                document.querySelectorAll('.hide-in-pdf').forEach(el => {
                    el.style.display = 'block';
                });
                const tempStyle = document.getElementById("pdf-temp-style");
                if (tempStyle) tempStyle.remove();

                // 5. RECHARGEMENT
                setTimeout(() => {
                    location.reload();
                }, 500);
            });
        }, 200);
    });
    
    </script>
  </body>


