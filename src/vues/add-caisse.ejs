<!DOCTYPE html>
<html lang="en">

  
<!-- Mirrored from buybootstrap.com/demos/medflex/medflex-admin-dashboard/add-staff.html by HTTrack Website Copier/3.x [XR&CO'2014], Thu, 15 May 2025 12:16:13 GMT -->
<%- include('head')%>

  <body>

    <!-- Page wrapper starts -->
    <div class="page-wrapper">

      <!-- App header starts -->
      <% if(user.Personnel.type_personnel === 'admin'){%>
        <%- include('header')%>
      <% }else{%>
        <%- include('header-staff')%>
      <% }%>
      <!-- App header ends -->

      <!-- Main container starts -->
      <div class="main-container">

        <!-- Sidebar wrapper starts -->
        <% if(user.Personnel.type_personnel === 'admin'){%>
          <%- include('menu')%>
        <% }else{%>
          <%- include('menu-staff')%>
        <% }%>
        <!-- Sidebar wrapper ends -->

        <!-- App container starts -->
        <div class="app-container">

          <!-- App hero header starts -->
          <div class="app-hero-header d-flex align-items-center">

            <!-- Breadcrumb starts -->
            <ol class="breadcrumb">
              <li class="breadcrumb-item">
                <i class="ri-home-8-line lh-1 pe-3 me-3 border-end"></i>
                <a href="/index">Accueil</a>
              </li>
              <li class="breadcrumb-item text-primary" aria-current="page">
                Ajouter une Nouvelle Caisse
              </li>
            </ol>
            <!-- Breadcrumb ends -->

            <!-- Sales stats starts -->
            
            <!-- Sales stats ends -->

          </div>
          <!-- App Hero header ends -->

          <!-- App body starts -->
          <div class="app-body">

            <% if(msg) { %>
              <div class="alert <%= tc || 'alert-info' %> alert-dismissible fade show" role="alert">
                <%= msg %>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
            <% } %>
            
            <div class="container mt-5">
              <!-- carte pour ajouter un caissier a une caisse existante -->
              <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="card-header bg-success text-white text-center p-4">
                    <h3 class="mb-0"><i class="fas fa-user-plus me-2"></i> Affecter un Caissier Supplémentaire</h3>
                </div>
                <div class="card-body p-5 bg-light">
                    <div class="alert alert-success border-0 shadow-sm d-flex align-items-center mb-4">
                        <i class="fas fa-link me-3 fa-2x"></i>
                        <div>
                            <h5 class="mb-0 text-success">Lier un Personnel à une Caisse</h5>
                            <small>Utilisez cette section pour permettre à un autre employé d'accéder à une caisse déjà créée.</small>
                        </div>
                    </div>
        
                    <form action="/assignCaisse" method="POST">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Sélectionner la Caisse</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-success border-success"><i class="fas fa-cash-register"></i></span>
                                    <select name="id_caisse" class="form-select border-success shadow-sm" required>
                                        <% if(caisse){ caisse.forEach(c => { %>
                                            <option value="<%= c.id_caisse %>"><%= c.nom %> (<%= c.type_lieu %>)</option>
                                        <% })} else { %>
                                            <option value="" disabled selected>Aucune Caisse disponible</option>
                                        <% } %>
                                    </select>
                                </div>
                            </div>
        
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Choisir le Caissier</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-success border-success"><i class="fas fa-user-tie"></i></span>
                                    <select name="id_personnel" class="form-select border-success shadow-sm" required>
                                        <% if(personnels){ personnels.forEach(p => { %>
                                            <option value="<%= p.Personnel.id_personnel %>"><%= p.Personnel.nom %> <%= p.Personnel.prenom %></option>
                                        <% })} else { %>
                                            <option value="" disabled selected>Aucun Personnel disponible</option>
                                        <% } %>
                                    </select>
                                </div>
                            </div>
        
                            <div class="col-12 d-grid mt-4">
                                <button type="submit" class="btn btn-success btn-lg shadow-sm fw-bold">
                                    <i class="fas fa-check-circle me-2"></i> VALIDER L'AFFECTATION
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
              </div>
              <br>
              <br>
              <!-- carde pour ajouter une caisse -->
                <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
                    <div class="card-header bg-primary text-white text-center p-4">
                        <h3 class="mb-0"><i class="fas fa-cash-register me-2"></i> Configuration de la Caisse</h3>
                    </div>
                    <div class="card-body p-5">
                        <div class="mb-5 text-center">
                            <label class="form-label fw-bold d-block mb-4 text-uppercase">1. Choisissez le Département</label>
                            <div class="d-flex flex-wrap gap-3 justify-content-center">
                                <button type="button" class="btn btn-outline-info p-3 shadow-sm btn-dept" onclick="updateLieuList('BarSimple', this)">
                                    <i class="fas fa-glass-cheers fa-2x mb-2"></i><br><b>BARS</b>
                                </button>
                                <button type="button" class="btn btn-outline-warning p-3 shadow-sm btn-dept" onclick="updateLieuList('BarVip', this)">
                                    <i class="fas fa-crown fa-2x mb-2"></i><br><b>VIP</b>
                                </button>
                                <button type="button" class="btn btn-outline-danger p-3 shadow-sm btn-dept" onclick="updateLieuList('CrazyClub', this)">
                                    <i class="fas fa-music fa-2x mb-2"></i><br><b>CLUBS</b>
                                </button>
                                <button type="button" class="btn btn-outline-success p-3 shadow-sm btn-dept" onclick="updateLieuList('Cuisine', this)">
                                    <i class="fas fa-utensils fa-2x mb-2"></i><br><b>CUISINE</b>
                                </button>
                                <button type="button" class="btn btn-outline-primary p-3 shadow-sm btn-dept" onclick="updateLieuList('Appartement', this)">
                                    <i class="fas fa-bed fa-2x mb-2"></i><br><b>APPART</b>
                                </button>
                                <button type="button" class="btn btn-outline-secondary p-3 shadow-sm btn-dept" onclick="updateLieuList('MaisonClose', this)">
                                    <i class="fas fa-door-closed fa-2x mb-2"></i><br><b>MAISONS</b>
                                </button>
                            </div>
                        </div>
        
                        <form action="/addCaisse" method="POST" id="caisseForm">
                            <div id="formContent" class="d-none animate__animated animate__fadeIn">
                                <div class="row g-4 mb-4">
                                    <div class="col-md-12">
                                        <div class="alert alert-info border-0 shadow-sm d-flex align-items-center">
                                            <i class="fas fa-info-circle me-3 fa-2x"></i>
                                            <div>
                                                <h5 class="mb-0" id="lieuDisplayTitle">Département sélectionné</h5>
                                                <small>Veuillez préciser l'emplacement exact ci-dessous.</small>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Précisez le Lieu (sous departement) </label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
                                            <select name="lieu_composite" id="lieuSelect" class="form-select border-primary" required>
                                                </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Nom de la Caisse</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fas fa-tag"></i></span>
                                            <input type="text" name="nom" class="form-control border-primary" placeholder="Ex: Caisse Comptoir 1" required>
                                        </div>
                                    </div>
        
                                    <div class="col-md-12">
                                        <label class="form-label fw-bold">Affecter à un Caissier</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fas fa-user-tie"></i></span>
                                            <select name="id_personnel" class="form-select border-primary" required>
                                                <!-- <option value="" disabled selected>Choisir un personnel...</option> -->
                                                <% personnels.forEach(p => { %>
                                                    <option value="<%= p.Personnel.id_personnel %>"><%= p.Personnel.nom %> <%= p.Personnel.prenom %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                    </div>
                                </div>
        
                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary btn-lg shadow">
                                        <i class="fas fa-save me-2"></i> ENREGISTRER LA CAISSE
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
                <br>
                <br>
                <!-- carte pour ajouter un suprimer un caissier d'une caisse existante a la quelle il a ete affecter -->
              <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="card-header bg-danger text-white text-center p-4">
                    <h3 class="mb-0"><i class="fas fa-user-plus me-2"></i>Retirer un caissier d'une caisse</h3>
                </div>
                <div class="card-body p-5 bg-light">
                    <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center mb-4">
                        <i class="fas fa-link me-3 fa-2x"></i>
                        <div>
                            <h5 class="mb-0 text-danger">Retiré un Personnel Lier à une Caisse</h5>
                            <small>Utilisez cette section pour retiré un employé lier à une caisse déjà créée.</small>
                        </div>
                    </div>
        
                    <form action="/desassignCaisse" method="POST">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Sélectionner la Caisse</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-danger border-danger"><i class="fas fa-cash-register"></i></span>
                                    <select name="id_caisse" id="caisseSelect" class="form-select border-danger shadow-sm" required>
                                        <% if(caisse){ caisse.forEach(c => { %>
                                            <option value="<%= c.id_caisse %>"><%= c.nom %> (<%= c.type_lieu %>)</option>
                                        <% })} %>
                                    </select>
                                </div>
                            </div>
        
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Choisir le caissier à retirer</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-danger border-danger"><i class="fas fa-user-tie"></i></span>
                                    <select name="id_personnel" id="personnelSelect" class="form-select border-danger shadow-sm" required>
                                        
                                    </select>
                                </div>
                            </div>
                            <div class="col-12 d-grid mt-4">
                                <button type="submit" class="btn btn-danger btn-lg shadow-sm fw-bold">
                                    <i class="fas fa-check-circle me-2"></i> VALIDER LE RETRAIT
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
              </div>
            </div>
        </div>
            <!-- Row ends -->
            
          </div>
          <!-- App body ends -->

          <!-- App footer starts -->
          <div class="app-footer bg-white">
            <span>© OneLove admin 2026</span>
          </div>
          <!-- App footer ends -->

        </div>
        <!-- App container ends -->

      </div>
      <!-- Main container ends -->

    </div>
    <!-- Page wrapper ends -->

    <!-- *************
			************ JavaScript Files *************
		************* -->
    <!-- Required jQuery first, then Bootstrap Bundle JS -->
    <%- include('script')%>
    <script src="/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
      window.addEventListener("pageshow", function (event) {
        var historyTraversal = event.persisted || 
                               (typeof window.performance != "undefined" && 
                                window.performance.navigation.type === 2);
        if (historyTraversal) {
            // Si l'utilisateur est revenu en arrière, on recharge la page proprement
            window.location.reload();
        }
    });
    
    </script>
    <script>
      // Chargement des données EJS de manière sécurisée
      // On utilise JSON.parse pour s'assurer que l'objet est bien formé
      const all_caisse = JSON.parse(`<%- JSON.stringify(caissesd) %>`);
      const databaseLieux = {
        BarSimple: JSON.parse(`<%- JSON.stringify(bars) %>`),
        BarVip: JSON.parse(`<%- JSON.stringify(vips) %>`),
        CrazyClub: JSON.parse(`<%- JSON.stringify(clubs) %>`),
        Cuisine: JSON.parse(`<%- JSON.stringify(cuisines) %>`),
        Appartement: JSON.parse(`<%- JSON.stringify(appartements) %>`),
        MaisonClose: JSON.parse(`<%- JSON.stringify(maisons) %>`),
      };

      console.log(JSON.parse(`<%- JSON.stringify(personnels) %>`));
  
      function updateLieuList(type, btnElement) {
          // Sélection des éléments du DOM
          const select = document.getElementById('lieuSelect');
          const formContent = document.getElementById('formContent'); // Vérifiez que cet ID existe sur votre div formulaire
          const displayTitle = document.getElementById('lieuDisplayTitle');
          const buttons = document.querySelectorAll('.btn-dept');
          const nomLieu = document.getElementById('nomLieu');
  
          // 1. Gestion visuelle des boutons (Couleurs et état actif)
          buttons.forEach(btn => {
              btn.classList.remove('active', 'btn-primary', 'text-white');
          });
          btnElement.classList.add('active', 'btn-primary', 'text-white');
  
          // 2. Récupération des données selon le type
          const lieux = databaseLieux[type];
          if (lieux && lieux.length > 0) {
              // Vider le select et ajouter l'option par défaut
              select.innerHTML = '';
  
              // Remplir le select dynamiquement
              lieux.forEach(l => {
                  const opt = document.createElement('option');
                  
                  // On détecte dynamiquement quel ID est présent (selon vos modèles)
                  const id = l.id_barSimple || l.id_barVip || l.id_cclub || l.id_cuisine || l.id_appart || l.id_mclose;
                  const nom = l.nom || l.nom_appart || l.nom_cuisine
                  
                  opt.value = `${type}\\${id}\\${nom}` ; // Format : "BarSimple-5"
                  opt.textContent = nom;
                  select.appendChild(opt);
              });
  
              // 3. Mise à jour du titre et affichage du formulaire
              if (displayTitle) displayTitle.innerHTML = '<i class="fas fa-check-circle me-2"></i> Département : ' + type;
              
              // On affiche le reste du formulaire
              if (formContent) {
                  formContent.classList.remove('d-none');
              }
          } else {
            //   alert("Aucun lieu trouvé pour la catégorie : " + type);
            // Remplacement de l'alert moche par SweetAlert2
                Swal.fire({
                    title: 'Aucun résultat',
                    text: `Désolé, aucun lieu trouvé pour la catégorie : ${type}`,
                    icon: 'warning',
                    confirmButtonColor: '#3085d6', // Tu peux mettre ta couleur de thème ici
                    confirmButtonText: 'OK',
                    background: '#ffffff',
                    showClass: {
                        popup: 'animate__animated animate__fadeInDown' // Animation fluide
                    }
                });
              // On cache le formulaire si aucun lieu n'existe
              if (formContent) {
                  formContent.classList.add('d-none');
              }
          }
      }

      const caisseSelect = document.getElementById('caisseSelect');
      const personnelSelect = document.getElementById('personnelSelect');

      function loadPersonnel(selectedCaisse) {
        const nb_caisse_personnel = all_caisse.find(
            caisse => caisse.id_caisse == selectedCaisse
        );

        // personnelSelect.innerHTML = '<option value="">-- Choisir un personnel --</option>';

        if (nb_caisse_personnel && nb_caisse_personnel.Personnels) {
            nb_caisse_personnel.Personnels.forEach(personnel => {
                personnelSelect.insertAdjacentHTML(
                    'beforeend',
                    `<option value="${personnel.id_personnel}">
                        ${personnel.nom} ${personnel.prenom}
                    </option>`
                );
            });
        }
    }

    // 🔥 Charger au démarrage
    loadPersonnel(caisseSelect.value);

    // 🔁 Sur changement
    caisseSelect.addEventListener('change', function() {
        loadPersonnel(this.value);
    });
  </script>
  </body>

